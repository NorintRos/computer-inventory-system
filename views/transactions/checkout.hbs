<section class="page-hero row-between">
  <div>
    <h1>Check out</h1>
    <p class="text-muted">Assign an available asset to a user. Optionally attach a document (e.g. sign-out form).</p>
  </div>
  <div class="row-actions">
    <a href="/transactions" class="btn btn-ghost">All transactions</a>
    <a href="/items" class="btn btn-ghost">Inventory</a>
  </div>
</section>

{{#if items.length}}
<form method="post" action="/transactions/checkout" enctype="multipart/form-data" class="card stack-form max-w-form">
  <label class="field">
    <span>Item</span>
    <select name="itemId" required>
      <option value="" disabled selected>— Select item —</option>
      {{#each items}}
        <option value="{{_id}}">{{itemId}} — {{brand}} {{model}} ({{category}})</option>
      {{/each}}
    </select>
  </label>

  <label class="field">
    <span>Assign to user</span>
    <select name="userId" required>
      <option value="" disabled selected>— Select user —</option>
      {{#each users}}
        <option value="{{_id}}">{{username}} ({{role}})</option>
      {{/each}}
    </select>
  </label>

  <label class="field">
    <span>Notes <span class="text-muted">(optional)</span></span>
    <textarea name="notes" rows="3" maxlength="1000" placeholder="Reason, location, ticket reference…"></textarea>
  </label>

  <label class="field">
    <span>Document <span class="text-muted">(optional)</span></span>
    <input type="file" name="document" accept=".pdf,.png,.jpg,.jpeg,.webp,.gif" />
  </label>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Complete check-out</button>
  </div>
</form>
{{else}}
<div class="card">
  <p class="text-muted">No available items to check out. <a href="/items">View inventory</a> or add assets.</p>
</div>
{{/if}}
