<section class="page-hero row-between">
  <div>
    <h1>{{#if isNew}}Add item{{else}}Edit item{{/if}}</h1>
    <p class="text-muted">{{#if isNew}}Create a new asset record.{{else}}Update details for {{item.itemId}}.{{/if}}</p>
  </div>
  <a href="/items" class="btn btn-ghost">Back to list</a>
</section>

{{#if isNew}}
<form method="post" action="/items" class="card stack-form max-w-form">
  <label class="field">
    <span>Item / asset ID</span>
    <input type="text" name="itemId" required />
  </label>
  <label class="field">
    <span>Serial number</span>
    <input type="text" name="serialNumber" required />
  </label>
  <label class="field">
    <span>Model</span>
    <input type="text" name="model" required />
  </label>
  <label class="field">
    <span>Brand</span>
    <input type="text" name="brand" required />
  </label>
  <label class="field">
    <span>Category</span>
    <select name="category" required>
      {{#each categories}}
        <option value="{{this}}">{{this}}</option>
      {{/each}}
    </select>
  </label>
  <label class="field">
    <span>Date acquired</span>
    <input type="date" name="dateAcquired" required />
  </label>
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Create item</button>
  </div>
</form>
{{else}}
<form method="post" action="/items/{{item._id}}" class="card stack-form max-w-form">
  <input type="hidden" name="_method" value="PUT" />
  <p class="text-muted">Item ID <strong>{{item.itemId}}</strong> cannot be changed.</p>

  <label class="field">
    <span>Serial number</span>
    <input type="text" name="serialNumber" value="{{item.serialNumber}}" required />
  </label>
  <label class="field">
    <span>Model</span>
    <input type="text" name="model" value="{{item.model}}" required />
  </label>
  <label class="field">
    <span>Brand</span>
    <input type="text" name="brand" value="{{item.brand}}" required />
  </label>
  <label class="field">
    <span>Category</span>
    <select name="category" required>
      {{#each categories}}
        <option value="{{this}}" {{#if (eq ../item.category this)}}selected{{/if}}>{{this}}</option>
      {{/each}}
    </select>
  </label>
  <label class="field">
    <span>Status</span>
    <select name="status" required>
      {{#each statuses}}
        <option value="{{this}}" {{#if (eq ../item.status this)}}selected{{/if}}>{{this}}</option>
      {{/each}}
    </select>
  </label>
  <label class="field">
    <span>Date acquired</span>
    <input type="date" name="dateAcquired" value="{{item.dateAcquired}}" required />
  </label>
  <label class="field">
    <span>Assigned to</span>
    <select name="assignedTo">
      <option value="">— Unassigned —</option>
      {{#each users}}
        <option value="{{_id}}" {{#if (eq ../selectedAssignee (toStringId _id))}}selected{{/if}}>{{username}} ({{role}})</option>
      {{/each}}
    </select>
  </label>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Save changes</button>
  </div>
</form>
{{#if (eq user.role "Admin")}}
  <form method="post" action="/items/{{item._id}}" class="card danger-zone mt-md" onsubmit="return confirm('Remove this item from inventory?');">
    <input type="hidden" name="_method" value="DELETE" />
    <p class="text-muted">Admin: soft-delete this record (hidden from default lists).</p>
    <button type="submit" class="btn btn-danger">Delete item</button>
  </form>
{{/if}}
{{/if}}
