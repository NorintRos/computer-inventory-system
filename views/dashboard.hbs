<section class="page-hero">
  <h1>Dashboard</h1>
  <p class="text-muted">Overview of inventory status.</p>
</section>

<div class="stat-grid">
  <a href="/items" class="stat-card">
    <span class="stat-value">{{stats.total}}</span>
    <span class="stat-label">Total items</span>
  </a>
  <a href="/items?status=Available" class="stat-card stat-available">
    <span class="stat-value">{{stats.available}}</span>
    <span class="stat-label">Available</span>
  </a>
  <a href="/items?status=In-Use" class="stat-card stat-inuse">
    <span class="stat-value">{{stats.inUse}}</span>
    <span class="stat-label">In use</span>
  </a>
  <a href="/items?status=Maintenance" class="stat-card stat-maintenance">
    <span class="stat-value">{{stats.maintenance}}</span>
    <span class="stat-label">Maintenance</span>
  </a>
  <a href="/items?status=Retired" class="stat-card stat-retired">
    <span class="stat-value">{{stats.retired}}</span>
    <span class="stat-label">Retired</span>
  </a>
</div>

<section class="card mt-lg">
  <h2>Quick links</h2>
  <ul class="link-list">
    <li><a href="/items">Browse inventory</a></li>
    <li><a href="/items/new">Add new item</a></li>
    <li><a href="/transactions">Transactions hub</a> — <a href="/transactions/checkout">check out</a> · <a href="/transactions/checkin">check in</a></li>
    <li><a href="/history">Item history</a> (pick an asset from inventory)</li>
  </ul>
</section>
